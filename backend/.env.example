# Application
APP_NAME=Authentra AI
APP_ENV=development
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://authentra:authentra@db:5432/authentra
SYNC_DATABASE_URL=postgresql://authentra:authentra@db:5432/authentra

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@authentra.ai
SMTP_FROM_NAME=Authentra AI
SMTP_TLS=true

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# LLM - Google Gemini (free tier)
GEMINI_API_KEY=your-gemini-api-key

# LLM Fallback - OpenRouter (free models)
OPENROUTER_API_KEY=your-openrouter-api-key

# Encryption
ENCRYPTION_KEY=your-32-byte-encryption-key-here!!

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# File limits
MAX_RESUME_SIZE_MB=10

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
