# ────────────────────────────────────────────────────────────────────────────
# Authentra AI — Environment Variables
# Copy this file to backend/.env and fill in all values before running.
# ────────────────────────────────────────────────────────────────────────────

# App
APP_NAME=Authentra AI
APP_ENV=development
SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32
DEBUG=true

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://authentra:authentra@db:5432/authentra
SYNC_DATABASE_URL=postgresql://authentra:authentra@db:5432/authentra

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email — Gmail: use App Password (16-char) not your regular password
# Enable 2FA → Google Account → Security → App Passwords → Mail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=your_16_char_app_password
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=Authentra AI
SMTP_TLS=true

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# LLM — Google Gemini (free tier at aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key

# LLM Fallback — OpenRouter (free models at openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key

# Encryption (must be exactly 32 characters)
ENCRYPTION_KEY=your_32_character_encryption_key!

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Limits
MAX_RESUME_SIZE_MB=10
